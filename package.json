{
  "name": "the-kitchen",
  "productName": "The Kitchen",
  "private": true,
  "version": "1.2.0",
  "description": "Everyday cooking recipes with serving-size scaling, weekly planner and shopping list.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "vite build && electron .",
    "electron:build": "vite build && electron-builder --win",
    "electron:build:mac": "vite build && electron-builder --mac",
    "ios:init": "vite build && npx cap add ios",
    "ios:sync": "vite build && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/filesystem": "^6.0.1",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.0"
  },
  "build": {
    "appId": "au.becskitchen.app",
    "productName": "The Kitchen",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "public/icon-512.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon-512.png"
    },
    "nsis": {
      "oneClick": true,
      "createDesktopShortcut": true
    }
  }
}